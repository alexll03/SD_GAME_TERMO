# ==============================================================================
# CLOCK  –  50 MHz oscillator
# ==============================================================================
NET "clk"   LOC = "E12"  | IOSTANDARD = LVCMOS33;
NET "clk"   TNM_NET = "clk";
TIMESPEC    TS_CLK = PERIOD "clk" 20 ns HIGH 50%;

# ==============================================================================
# RESET  –  Push-button BTN_SOUTH
# ==============================================================================
NET "rst"   LOC = "T15"  | IOSTANDARD = LVCMOS33;

# ==============================================================================
# PS/2 KEYBOARD CONNECTOR
# Both lines are open-collector
# ==============================================================================
NET "ps2_clk"   LOC = "W12"  | IOSTANDARD = LVCMOS33 | PULLUP;
NET "ps2_data"  LOC = "V11"  | IOSTANDARD = LVCMOS33 | PULLUP;

# ==============================================================================
# LCD – 4-bit
# Control lines
# ==============================================================================
NET "lcd_rs"  LOC = "Y14" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "lcd_rw"  LOC = "W13" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "lcd_e"   LOC = "AB4" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;

# Data bus – upper nibble only (D7..D4)
NET "lcd_db<4>" LOC = "AA12" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "lcd_db<5>" LOC = "Y16" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "lcd_db<6>" LOC = "AB16" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "lcd_db<7>" LOC = "Y15" | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;

# ==============================================================================
# STATUS LEDs
#   led[0]  P1 word entered (LED0 / DS1)
#   led[1]  Player 2 wins  (LED1 / DS2)
#   led[2]  Game over/lose (LED2 / DS3)
# ==============================================================================
NET "led<0>" LOC = "R20"  | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "led<1>" LOC = "T19"  | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;
NET "led<2>" LOC = "U20"  | IOSTANDARD = LVCMOS33 | SLEW = SLOW | DRIVE = 4;

# ==============================================================================
# Timing constraints
# ==============================================================================
# Allow up to 20 ns path for all synchronous paths (one clock cycle at 50 MHz)
NET "ps2_clk"  TIG;   # PS/2 clock crosses domains; false path
NET "ps2_data" TIG;   # PS/2 data  crosses domains; false path
